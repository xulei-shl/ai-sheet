{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI-Sheet",
  "version": "0.1.0",
  "identifier": "com.ai-sheet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Sheet",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../.pi/": ".pi/",
      "../src-agent/dist/": "src-agent/dist/"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://releases.ai-sheet.dev/{{target}}/{{current_version}}"],
      "dialog": true,
      "pubkey": ""
    }
  }
}
